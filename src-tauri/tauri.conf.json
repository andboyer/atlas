{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atlas",
  "version": "0.1.4",
  "identifier": "com.andboyer.atlas",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atlas",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "© 2026 Andre Boyer",
    "shortDescription": "Atlas — map your network. AI-assisted Wi-Fi diagnostics.",
    "longDescription": "Atlas continuously charts your Wi-Fi and LAN, detects complex network issues (channel interference, roaming, AV-over-IP multicast, rogue APs), and provides AI-powered actionable recommendations.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist",
      "exceptionDomain": null,
      "signingIdentity": "-",
      "providerShortName": null
    },
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-dev", "libssl-dev"]
      }
    }
  },
  "plugins": {}
}
